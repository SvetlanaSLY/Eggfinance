        toggleAnnual.classList.remove('active-toggle', 'font-bold');
        toggleAnnual.classList.add('text-on-surface-variant', 'font-medium');
    });

    toggleAnnual.addEventListener('click', () => {
        toggleAnnual.classList.add('active-toggle');
        toggleAnnual.classList.remove('text-on-surface-variant', 'font-medium');
        toggleAnnual.classList.add('font-bold');
        toggleMonthly.classList.remove('active-toggle', 'font-bold');
        toggleMonthly.classList.add('text-on-surface-variant', 'font-medium');
    });
</script>


