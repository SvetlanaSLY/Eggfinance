    <script>
        // Billing Toggle Functionality
        const billingToggle = document.getElementById('billingToggle');
        const billingSwitch = document.getElementById('billingSwitch');
        const monthlyLabel = document.getElementById('monthlyLabel');
        const annualLabel = document.getElementById('annualLabel');
        const priceAmounts = document.querySelectorAll('.price-amount');

        billingToggle.addEventListener('click', (e) => {
            e.preventDefault();
            billingSwitch.checked = !billingSwitch.checked;
            toggleBilling();
        });

        function toggleBilling() {
            const isAnnual = billingSwitch.checked;
            
            if (isAnnual) {
                billingToggle.classList.add('annual');
                monthlyLabel.classList.remove('active');
                annualLabel.classList.add('active');
            } else {
                billingToggle.classList.remove('annual');
                monthlyLabel.classList.add('active');
                annualLabel.classList.remove('active');
            }

            // Animate price change
            priceAmounts.forEach(amount => {
                amount.classList.remove('price-animate');
                void amount.offsetWidth; // Trigger reflow
                amount.classList.add('price-animate');

                const monthlyPrice = amount.dataset.monthly;
                const annualPrice = amount.dataset.annual;
                const newPrice = isAnnual ? annualPrice : monthlyPrice;
                
                // Format with dots for thousands
                amount.textContent = formatPrice(newPrice) + '€';
            });
        }

        function formatPrice(price) {
            return price.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ".");
        }

        // CTA Button Click
        document.querySelectorAll('.cta-button').forEach(button => {
            button.addEventListener('click', function() {
                const card = this.closest('.pricing-card');
                const editionName = card.querySelector('.edition-name').textContent;
                console.log('Demo requested for:', editionName);
                // Add your demo request logic here
            });
        });

        // Navbar scroll effect
        window.addEventListener('scroll', () => {
            const nav = document.querySelector('nav');
            if (window.scrollY > 50) {
                nav.style.boxShadow = '0 4px 6px -1px rgba(0, 0, 0, 0.1)';
            } else {
                nav.style.boxShadow = 'none';
            }
        });
    </script>
</body>
